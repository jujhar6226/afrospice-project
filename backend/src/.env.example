PORT=5000
NODE_ENV=production

# Development: MONGO_URI=memory (in-process replica set, no mongod). Or local replica:
# MONGO_URI=mongodb://127.0.0.1:27018/afrospice?replicaSet=rs0
# Production / Atlas:
MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/afrospice
FRONTEND_ORIGIN=https://app.example.com
PUBLIC_BASE_URL=https://api.example.com
TRUST_PROXY=1
ENFORCE_HTTPS=true

JWT_SECRET=replace-with-a-64-character-secret
JWT_ISSUER=afrospice-api
JWT_AUDIENCE=afrospice-workspace
JWT_EXPIRES=12h

AUTH_COOKIE_NAME=__Host-afrospice_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
PYTHON_ML_BIN=

SESSION_IDLE_TIMEOUT_MINUTES=720
SESSION_ABSOLUTE_TIMEOUT_MINUTES=10080
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_CHANGE_PIN_RATE_LIMIT_MAX=8

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
EXTERNAL_ASSISTANT_ENABLED=false

BOOTSTRAP_SAMPLE_DATA=false
