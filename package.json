{
  "scripts": {
    "dev": "node ./scripts/dev-workspace.js",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "db:setup-local-replica": "npm --prefix backend run db:setup-local-replica",
    "db:bootstrap": "npm --prefix backend run db:bootstrap",
    "db:import-history": "node ./backend/scripts/import-historical-data.js",
    "db:cleanup-runtime": "npm --prefix backend run db:cleanup-runtime",
    "db:migrate-dates": "npm --prefix backend run db:migrate-dates",
